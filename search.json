---
layout: null
---
{% assign articles = site.pages | where_exp: "p", "p.slug and p.title" %}[
{% for item in articles %}  {
    "title": {{ item.title | jsonify }},
    "url": {{ item.url | relative_url | jsonify }},
    "collection": {{ item.collection | default: "" | jsonify }},
    "section": {{ item.section | default: "" | jsonify }},
    "content": {{ item.content | strip_html | truncatewords: 200 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}]
