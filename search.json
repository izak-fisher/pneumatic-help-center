---
layout: null
---
[{% assign first = true %}{% for p in site.pages %}{% if p.slug and p.title %}{% if first == false %},{% endif %}{% assign first = false %}
  {
    "title": {{ p.title | jsonify }},
    "url": {{ p.url | relative_url | jsonify }},
    "collection": {{ p.collection | default: "" | jsonify }},
    "section": {{ p.section | default: "" | jsonify }},
    "content": {{ p.content | strip_html | truncatewords: 200 | jsonify }}
  }{% endif %}{% endfor %}
]
